# NovoMCP env vars — copy this to `.env` and fill in what you have.
# Everything below is optional. The engine boots with none of these set
# (you get 11 always-available tools). Each block below unlocks more tools.
#
# The engine reads .env at boot via python-dotenv. Shell env vars ALWAYS
# win — .env only fills gaps. Never commit a real .env with secrets.

# ============================================================================
# Omics data (v1.1.x — unlocks target_discovery, validate_target, stratify_patients)
# ============================================================================
# Postgres connection string, or a path to a local SQLite bundle.
# NOVOMCP_DB_HOST=postgresql://novomcp:password@localhost:5432/novomcp

# ============================================================================
# Molecule index (unlocks search_similar, filter_molecules, tree-guided retrieval)
# ============================================================================
# Point at any service that indexes molecules. FAVES, the v1.1.5 reference
# similarity-index server, a self-hosted parquet reader — all work.
# NOVOMCP_MOLECULE_INDEX_URL=http://localhost:8080

# ============================================================================
# Compliance service (unlocks check_compliance)
# ============================================================================
# Point at any compliance service. FAVES-as-API, or your own DEA/PAINS/etc.
# rule engine.
# NOVOMCP_COMPLIANCE_URL=http://localhost:8081

# ============================================================================
# ADMET predictions (unlocks predict_admet)
# ============================================================================
# ADDIE_MODELS_URL=http://localhost:8003

# ============================================================================
# GPU compute stack (unlocks docking, MD, and full autonomous discovery `agm`)
# ============================================================================
# AUTODOCK_GPU_URL=http://localhost:8004     # docking (dock_molecules, dock_with_strain)
# GROMACS_MD_URL=http://localhost:8005       # MD (run_molecular_dynamics, generate_dynamics)
# OPENFOLD3_URL=http://localhost:8006        # structure prediction
# LEAD_OPTIMIZATION_URL=http://localhost:8007
# MOLMIM_OPTIMIZER_URL=http://localhost:8008

# ============================================================================
# QM / NNP / property services (v1.6.x)
# ============================================================================
# NOVOMCP_QM_URL=http://localhost:8009
# NOVOMCP_NNP_URL=http://localhost:8010
# NOVOMCP_PROPERTIES_URL=http://localhost:8011
# NOVOMCP_NEB_URL=http://localhost:8012

# ============================================================================
# NovoExpert-3 clinical outcomes (v1.7.x — MIT weights)
# ============================================================================
# NOVOEXPERT_URL=http://localhost:8013

# ============================================================================
# Literature via Pinecone (v1.2.x adds public PubMed fallback)
# ============================================================================
# PINECONE_API_KEY=your-pinecone-key

# ============================================================================
# Materials Project (unlocks search_materials_project)
# ============================================================================
# Free — sign up at https://materialsproject.org/
# MP_API_KEY=your-mp-key

# ============================================================================
# Funnel-persistence backend (v1.8.x — audit log, credit ledger, file storage)
# ============================================================================
# FUNNEL_BACKEND_URL=http://localhost:8014

# ============================================================================
# Behavior toggles
# ============================================================================
# NOVOMCP_NO_UPDATE_CHECK=1      # disable boot-time GitHub Releases check
# NOVOMCP_SHOW_HIDDEN_TOOLS=1    # show all 67 tools regardless of what's wired
# NOVOMCP_SHOW_HIDDEN_PROMPTS=1  # show all prompts regardless of what's wired
